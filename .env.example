# Todos os valores abaixo são os defaults de produção, já embutidos no código
# (são valores públicos: chave client-side do Soketi e hosts). O projeto roda
# sem .env; crie um .env.local só para apontar para um ambiente diferente.

VITE_API_URL=https://api.pipeelo.com/v1

VITE_SOKETI_KEY=edf3e8e06df44054379686a760935487
VITE_SOKETI_HOST=soketi.pipeelo.com
VITE_SOKETI_PORT=443
VITE_SOKETI_CLUSTER=m1
# "false" para Soketi local sem TLS (ex.: localhost:6001)
VITE_SOKETI_TLS=true
